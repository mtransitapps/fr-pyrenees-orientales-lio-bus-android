{
    "default_route_id_enabled": true,
    "use_route_short_name_for_route_id": true,
    "default_route_long_name_enabled": true,
    "direction_finder_enabled": true,
    "trip_headsign_remove_via": true,
    "direction_headsign_cleaners": [
        {
            "regex": "PLA DE BARRES-CABANASSE",
            "ignore_case": true,
            "is_word": true,
            "replacement": "Pla De Barres - Cabanasse"
        },
        {
            "regex": "CABANASSE-PLA DE BARRES",
            "ignore_case": true,
            "is_word": true,
            "replacement": "Cabanasse - Pla De Barres"
        },
        {
            "regex": "(?U)^(([^-]+-\\s+)+([^-]+))",
            "replacement": "$3",
            "comment": "Keep only after last '-'"
        }
    ],
    "trip_headsign_cleaners": [
        {
            "regex": "^((?:(?! - )[\\s\\S])*)(\\s+-\\s+)(.+)$",
            "replacement": "$1: $3",
            "comment": "Keep 'city: location' (city more important when different than direction)"
        }
    ],
    "trip_headsign_cleaners_old": [
        {
            "regex": "^((?:(?! - )[\\s\\S])*)(\\s+-\\s+)(.+)$",
            "replacement": "$1: $3",
            "comment": "Keep 'city: location'"
        }
    ],
    "stop_name_cleaners": [
        {
            "regex": "^((?:(?! - )[\\s\\S])*)(\\s+-\\s+)(.+)$",
            "replacement": "$1: $3"
        }
    ]
}
